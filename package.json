{
  "name": "compiler",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint:js": "eslint .",
    "lint": "npm run lint:js && npm run check",
    "backend": "node server/index.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up",
    "docker:up:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "dev:stack": "concurrently -k -n backend,frontend -c green,blue \"npm:backend\" \"npm:dev\"",
    "dev:all": "node scripts/dev-all.mjs",
    "setup:toolchain": "node scripts/setup-toolchain.mjs",
    "doctor": "node scripts/doctor.mjs",
    "test:backend": "node scripts/test-backend.mjs"
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "lucide-svelte": "^0.460.0",
    "pidusage": "^4.0.1",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.11.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.0.0",
    "vite": "^5.4.0"
  }
}
