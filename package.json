{
  "name": "compiler",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@11.12.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start:frontend": "node build",
    "start:backend": "tsx server/index.ts",
    "start:prod": "node scripts/start-production.mjs",
    "smoke:prod": "node scripts/smoke-production.mjs",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint:js": "eslint .",
    "lint": "npm run lint:js && npm run check",
    "backend": "tsx server/index.ts",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up",
    "docker:up:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "dev:stack": "concurrently -k -n backend,frontend -c green,blue \"npm:backend\" \"npm:dev\"",
    "dev:all": "node scripts/dev-all.mjs",
    "setup:toolchain": "node scripts/setup-toolchain.mjs",
    "doctor": "node scripts/doctor.mjs",
    "test:backend": "node scripts/test-backend.mjs",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "lucide-svelte": "^0.460.0",
    "pidusage": "^4.0.1",
    "tar": "^7.5.13",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.11.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.0.0",
    "vite": "^5.4.0"
  },
  "overrides": {
    "ajv": "6.14.0",
    "flatted": "3.4.2",
    "minimatch": "3.1.5",
    "rollup": "4.60.0"
  }
}
