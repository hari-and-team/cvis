# Frontend
# Leave empty when the frontend and backend are deployed in the same Vercel project.
PUBLIC_API_BASE=

# interactive: stateful backend with live stdin support
# serverless: stateless Vercel execution via POST /api/execute
PUBLIC_EXECUTION_MODE=interactive

# Local Vite proxy target for `npm run dev`
VITE_API_PROXY_TARGET=http://localhost:3001

# Backend / API
PORT=3001
BACKEND_HOST=127.0.0.1
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Optional preview-origin support, for example:
# CORS_ORIGIN_REGEX=^https://cvis-frontend-.*\\.vercel\\.app$
CORS_ORIGIN_REGEX=
CORS_METHODS=GET,HEAD,POST,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_MAX_AGE_SECONDS=86400

TRUST_PROXY=false
REQUIRE_HTTPS=false
HTTPS_PUBLIC_ORIGIN=

# Compiler/runtime
CVIS_GCC_PATH=

# Optional OpenAI semantic analysis
OPENAI_API_KEY=
OPENAI_ANALYZE_MODEL=gpt-5-mini
